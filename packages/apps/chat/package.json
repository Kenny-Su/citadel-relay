{
  "name": "@citadel/app-chat",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js"
    }
  },
  "citadel": {
    "appId": "chat",
    "label": "Chat",
    "defaultSpaceId": "general",
    "persistence": "sqlite",
    "version": "0.1.0",
    "client": {
      "subpath": "./client",
      "registrationExport": "chatClientRegistration"
    },
    "server": {
      "subpath": "./server",
      "registrationExport": "chatServerRegistration"
    }
  },
  "scripts": {
    "prebuild": "citadel-generate-app-metadata --package-dir .",
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "prebuild:watch": "citadel-generate-app-metadata --package-dir .",
    "build:watch": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "pretypecheck": "citadel-generate-app-metadata --package-dir .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests"
  },
  "dependencies": {
    "@citadel/platform": "0.1.0",
    "nanoid": "^5.1.5"
  },
  "devDependencies": {
    "@types/node": "^24.0.4",
    "@types/react": "^19.1.8",
    "react": "^19.1.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  }
}
