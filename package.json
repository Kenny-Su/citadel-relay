{
  "name": "citadel-platform",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/platform"
  ],
  "engines": {
    "node": ">=24.14.1 <25"
  },
  "scripts": {
    "generate:local-app-metadata": "node scripts/generate-local-app-metadata.mjs",
    "check:local-app-metadata": "node scripts/generate-local-app-metadata.mjs --check",
    "generate:bundled-apps": "node scripts/generate-bundled-apps.mjs",
    "check:bundled-apps": "node scripts/generate-bundled-apps.mjs --check",
    "predev": "npm run build:packages && npm run generate:bundled-apps",
    "dev": "concurrently \"npm run dev:packages\" \"npm run dev:server\" \"npm run dev:client\"",
    "dev:packages": "npm run build:watch -w @citadel/platform",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "tsx watch src/server/index.ts",
    "prestart": "npm run build:packages && npm run generate:bundled-apps",
    "start": "tsx src/server/index.ts",
    "build": "npm run build:packages && npm run generate:bundled-apps && npm run typecheck && npm run build:client",
    "build:client": "vite build",
    "build:packages": "npm run build:platform && npm run install:local-external-apps",
    "build:platform": "npm run build -w @citadel/platform",
    "install:local-external-apps": "node scripts/install-local-external-apps.mjs --skip-platform-build",
    "pack:local-package": "node scripts/pack-local-package.mjs",
    "clean:packages": "npm run clean -w @citadel/platform",
    "typecheck": "npm run typecheck:client && npm run typecheck:server && npm run typecheck:packages",
    "typecheck:client": "tsc -p tsconfig.json --noEmit",
    "typecheck:server": "tsc -p tsconfig.server.json --noEmit",
    "typecheck:packages": "npm run typecheck -w @citadel/platform",
    "pretest": "npm run build:packages && npm run generate:bundled-apps",
    "test": "npm run check:local-app-metadata && npm run check:bundled-apps && vitest run",
    "test:production": "npm run build && vitest run tests/server/production.test.ts",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@citadel/platform": "0.1.0",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.3",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io-client": "^4.8.1",
    "tsx": "^4.20.3",
    "typescript": "^6.0.3",
    "vite": "^8.0.16"
  },
  "devDependencies": {
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/express": "^5.0.3",
    "@types/node": "^24.0.4",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "chess.js": "^1.4.0",
    "jsdom": "^29.1.1",
    "vitest": "^4.1.9"
  }
}
