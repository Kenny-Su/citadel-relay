{
  "name": "@citadel-platform/platform",
  "version": "0.1.0",
  "type": "module",
  "files": [
    "dist"
  ],
  "bin": {
    "citadel-generate-app-metadata": "dist/generateAppMetadataCli.js"
  },
  "exports": {
    "./app": {
      "types": "./dist/app.d.ts",
      "import": "./dist/app.js"
    },
    "./client": {
      "types": "./dist/client.d.ts",
      "import": "./dist/client.js"
    },
    "./server-app": {
      "types": "./dist/server-app.d.ts",
      "import": "./dist/server-app.js"
    },
    "./persistence": {
      "types": "./dist/persistence.d.ts",
      "import": "./dist/persistence.js"
    },
    "./server": {
      "types": "./dist/server.d.ts",
      "import": "./dist/server.js"
    },
    "./validation": {
      "types": "./dist/validation.d.ts",
      "import": "./dist/validation.js"
    }
  },
  "scripts": {
    "build": "npm run clean && tsc -p tsconfig.build.json",
    "build:watch": "tsc -p tsconfig.build.json --watch --preserveWatchOutput",
    "clean": "node -e \"fs.rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "vitest run tests"
  },
  "dependencies": {
    "express": "^5.1.0",
    "nanoid": "^5.1.5",
    "socket.io": "^4.8.1"
  },
  "devDependencies": {
    "vitest": "^4.1.9"
  },
  "peerDependencies": {
    "react": "^19.1.0"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  }
}
