{
  "compilerOptions": {
    "target": "ES2022",
    "useDefineForClassFields": true,
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "allowJs": false,
    "skipLibCheck": true,
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "baseUrl": ".",
    "ignoreDeprecations": "6.0",
    "paths": {
      "@citadel/platform/app": ["packages/platform/app.ts"],
      "@citadel/platform/client": ["packages/platform/client.ts"],
      "@citadel/platform/server-app": ["packages/platform/server-app.ts"],
      "@citadel/platform/persistence": ["packages/platform/persistence.ts"],
      "@citadel/platform/server": ["packages/platform/server.ts"],
      "@citadel/platform/validation": ["packages/platform/validation.ts"],
      "@citadel/app-chat": ["packages/apps/chat/index.ts"],
      "@citadel/app-chat/client": ["packages/apps/chat/client.ts"],
      "@citadel/app-chat/server": ["packages/apps/chat/server.ts"],
      "@citadel/app-chat/validation": ["packages/apps/chat/validation.ts"],
      "@citadel/app-chess": ["packages/apps/chess/index.ts"],
      "@citadel/app-chess/client": ["packages/apps/chess/client.ts"],
      "@citadel/app-chess/server": ["packages/apps/chess/server.ts"],
      "@citadel/app-snake": ["packages/apps/snake/index.ts"],
      "@citadel/app-snake/client": ["packages/apps/snake/client.ts"],
      "@citadel/app-snake/server": ["packages/apps/snake/server.ts"]
    },
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "jsx": "react-jsx"
  },
  "include": ["src/client", "vitest.setup.ts"]
}
